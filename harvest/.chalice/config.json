{
  "version": "2.0",
  "app_name": "harvest",
  "stages": {
    "dev": {
      "api_gateway_stage": "api",
      "lambda_functions": {
        "rebuild_outputs": {
          "lambda_timeout": 900,
          "lambda_memory_size": 512
        },
        "merge_tweets_into_monthfile": {
          "lambda_timeout": 300
        },
        "rebuild_month_summary": {
          "lambda_timeout": 900,
          "lambda_memory_size": 512
        },
        "collect_reports_manually": {
          "lambda_timeout": 300,
          "lambda_memory_size": 256
        }
      }
    }
  }
}
